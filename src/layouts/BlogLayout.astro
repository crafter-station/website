---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '@/i18n/utils';

type Props = {
  post: CollectionEntry<'blog'>;
};

const { post } = Astro.props;
const { title, description, pubDate, updatedDate } = post.data;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);
---

<BaseLayout lang={lang} title={`${title} — Crafter Station`} description={description}>
  <Nav />

  <main>
    <!-- Article header -->
    <section class="border-b border-divider px-6 py-16 max-w-[800px] mx-auto">
      <a
        href={tp('/blog')}
        class="text-sm text-muted-foreground hover:text-foreground transition-colors mb-10 inline-block"
      >
        ← {t('blog.cta').replace(' →', '')}
      </a>

      <div class="flex flex-wrap items-center gap-4 mt-6 mb-6">
        <time class="text-xs text-bullet">
          {pubDate.toLocaleDateString(
            lang === 'pt-br' ? 'pt-BR' : lang === 'es' ? 'es-ES' : 'en-US',
            { year: 'numeric', month: 'long', day: 'numeric' }
          )}
        </time>
        {updatedDate && (
          <span class="text-xs text-bullet">
            Updated: {updatedDate.toLocaleDateString(
              lang === 'pt-br' ? 'pt-BR' : lang === 'es' ? 'es-ES' : 'en-US',
              { year: 'numeric', month: 'long', day: 'numeric' }
            )}
          </span>
        )}
      </div>

      <h1 class="text-2xl md:text-3xl font-bold text-foreground leading-tight mb-4">{title}</h1>
      <p class="text-sm text-muted-foreground leading-relaxed">{description}</p>
    </section>

    <!-- Article body -->
    <article class="px-6 py-16 max-w-[800px] mx-auto">
      <div class="prose prose-invert max-w-none
        [&_h1]:font-bold [&_h1]:text-foreground [&_h1]:text-2xl [&_h1]:mt-12 [&_h1]:mb-4
        [&_h2]:font-bold [&_h2]:text-foreground [&_h2]:text-xl [&_h2]:mt-12 [&_h2]:mb-4
        [&_h3]:font-bold [&_h3]:text-foreground [&_h3]:text-lg [&_h3]:mt-8 [&_h3]:mb-3
        [&_p]:text-muted-foreground [&_p]:leading-relaxed [&_p]:mb-4
        [&_a]:text-foreground [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-muted-foreground
        [&_strong]:text-foreground [&_strong]:font-bold
        [&_code]:text-foreground [&_code]:bg-secondary [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-xs [&_code]:before:content-none [&_code]:after:content-none
        [&_pre]:bg-secondary [&_pre]:border [&_pre]:border-divider [&_pre]:p-4 [&_pre]:overflow-x-auto [&_pre]:rounded-none
        [&_pre_code]:bg-transparent [&_pre_code]:p-0
        [&_blockquote]:border-l-2 [&_blockquote]:border-divider [&_blockquote]:pl-6 [&_blockquote]:ml-0 [&_blockquote]:text-muted-foreground
        [&_ul]:list-none [&_ul]:pl-0
        [&_ul_li]:before:content-['[*]'] [&_ul_li]:before:text-bullet [&_ul_li]:before:mr-3 [&_ul_li]:before:text-sm [&_ul_li]:text-muted-foreground [&_ul_li]:mb-2 [&_ul_li]:flex [&_ul_li]:items-start [&_ul_li]:gap-2
        [&_ol]:list-decimal [&_ol]:pl-6 [&_ol_li]:text-muted-foreground [&_ol_li]:mb-2
        [&_img]:border [&_img]:border-divider [&_img]:w-full
        [&_hr]:border-divider [&_hr]:my-8
      ">
        <slot />
      </div>
    </article>
  </main>

  <SiteFooter />
</BaseLayout>
