---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '@/i18n/utils';
import { teamMembers } from '@/lib/constants/team';

export function getStaticPaths() {
  return teamMembers.map(member => ({
    params: { member: member.username },
    props: { member },
  }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);

const { member } = Astro.props;

type Social = { label: string; href: string; icon: string };

const socials = [
  member.github    && { label: 'GitHub',    href: member.github,    icon: 'github' },
  member.x         && { label: 'X',          href: member.x,         icon: 'x' },
  member.linkedin  && { label: 'LinkedIn',   href: member.linkedin,  icon: 'linkedin' },
  member.instagram && { label: 'Instagram',  href: member.instagram, icon: 'instagram' },
  member.website   && { label: 'Website',    href: member.website,   icon: 'globe' },
].filter(Boolean) as Social[];

const bio = (member.bio as Record<string, string>)[lang] ?? member.bio['en'];

// Extract cal username slug from cal URL for embed (e.g. "cuevaio/30min")
const calSlug = member.cal ? member.cal.replace('https://cal.com/', '') : null;
---

<BaseLayout
  lang={lang}
  title={`${member.name} — Crafter Station`}
  description={bio}
  ogImage={`/og/team/${member.username}.png`}
>
  <Nav />

  <main>
    <!-- Member header -->
    <section class="border-b border-divider px-6 py-16 max-w-[1280px] mx-auto">
      <a
        href={tp('/team')}
        class="text-sm text-muted-foreground hover:text-foreground transition-colors mb-10 inline-block"
      >
        {t('member.back')}
      </a>

      <div class="flex flex-col sm:flex-row gap-8 mt-6">
        <!-- Photo -->
        <div class="w-24 h-24 sm:w-32 sm:h-32 overflow-hidden shrink-0 border border-divider">
          <img
            src={member.photoUrl}
            alt={member.name}
            class="w-full h-full object-cover"
          />
        </div>

        <!-- Name / role / location -->
        <div class="flex flex-col justify-center">
          <h1 class="text-2xl md:text-3xl font-bold text-foreground leading-tight">{member.name}</h1>
          <p class="text-sm text-muted-foreground mt-1">{member.position}</p>
          {member.location && (
            <p class="text-xs text-bullet mt-1">{member.location}</p>
          )}
        </div>
      </div>
    </section>

    <!-- Bio -->
    <section class="border-b border-divider px-6 py-12 max-w-[1280px] mx-auto">
      <div class="flex items-start gap-4 max-w-2xl">
        <span class="text-bullet text-sm shrink-0 mt-0.5 select-none">[*]</span>
        <p class="text-sm text-muted-foreground leading-relaxed">{bio}</p>
      </div>
    </section>

    <!-- Skills -->
    {member.skills.length > 0 && (
      <section class="border-b border-divider px-6 py-12 max-w-[1280px] mx-auto">
        <h2 class="text-xs font-bold text-bullet mb-6 uppercase tracking-widest">{t('member.skills')}</h2>
        <div class="flex flex-wrap gap-2">
          {member.skills.map(skill => (
            <span class="px-3 py-1.5 border border-divider text-xs text-muted-foreground hover:border-muted-foreground hover:text-foreground transition-colors">
              {skill}
            </span>
          ))}
        </div>
      </section>
    )}

    <!-- Connect -->
    {socials.length > 0 && (
      <section class="border-b border-divider px-6 py-12 max-w-[1280px] mx-auto">
        <h2 class="text-xs font-bold text-bullet mb-6 uppercase tracking-widest">{t('member.connect')}</h2>
        <div class="flex flex-col gap-0 divide-y divide-divider border-t border-divider max-w-sm">
          {socials.map(link => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center justify-between py-3 hover:bg-secondary transition-colors -mx-6 px-6"
              data-track="social_click"
              data-track-platform={link.icon}
              data-track-location={`team_member_${member.username}`}
            >
              <span class="flex items-center gap-3 text-sm text-muted-foreground group-hover:text-foreground transition-colors">
                {link.icon === 'github' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                  </svg>
                )}
                {link.icon === 'x' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                )}
                {link.icon === 'linkedin' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                )}
                {link.icon === 'instagram' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
                  </svg>
                )}
                {link.icon === 'globe' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                  </svg>
                )}
                {link.label}
              </span>
              <span class="text-muted-foreground group-hover:text-foreground transition-colors text-sm">→</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Book a meeting (Cal.com embed) -->
    {member.cal && calSlug && (
      <section class="border-b border-divider" style="background:#111111;">
        <div class="px-6 pt-12 pb-8 max-w-[1280px] mx-auto">
          <h2 class="text-xs font-bold text-bullet mb-2 uppercase tracking-widest">{t('member.cal.heading')}</h2>
          <p class="text-sm text-muted-foreground mb-0 max-w-xl">{t('member.cal.sub')}</p>
        </div>
        <div
          id={`cal-embed-${member.username}`}
          class="max-w-[1280px] mx-auto"
          style="width:100%;height:660px;overflow:scroll;"
          data-member={member.username}
        ></div>
      </section>
    )}
  </main>

  <SiteFooter />
</BaseLayout>

{member.cal && calSlug && (
  <script define:vars={{ calSlug, memberId: member.username }} is:inline>
    (function(C, A, L) {
      var p = function(a, ar) { a.q.push(ar); };
      var d = C.document;
      C.Cal = C.Cal || function() {
        var cal = C.Cal;
        var ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          var api = function() { p(api, arguments); };
          var namespace = ar[1];
          api.q = api.q || [];
          if (typeof namespace === "string") {
            cal.ns[namespace] = cal.ns[namespace] || api;
            p(cal.ns[namespace], ar);
            p(cal, ["initNamespace", namespace]);
          } else {
            p(cal, ar);
          }
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");

    Cal("init", memberId, { origin: "https://app.cal.com" });

    Cal.ns[memberId]("inline", {
      elementOrSelector: "#cal-embed-" + memberId,
      config: { layout: "month_view", useSlotsViewOnSmallScreen: "true", theme: "dark" },
      calLink: calSlug,
    });

    Cal.ns[memberId]("ui", {
      cssVarsPerTheme: {
        dark: {
          "cal-brand": "#F2EDED",
          "cal-bg": "#131010",
          "cal-bg-emphasis": "#1e1b1b",
          "cal-bg-subtle": "#1a1717",
          "cal-border": "#3D3838",
          "cal-border-emphasis": "#716B6A",
          "cal-text": "#F2EDED",
          "cal-text-emphasis": "#F2EDED",
          "cal-text-subtle": "#7F7A7A"
        }
      },
      hideEventTypeDetails: false,
      layout: "month_view"
    });
  </script>
)}

{member.cal && calSlug && (
  <script>
    import { track } from '@vercel/analytics';
    const el = document.querySelector('[data-member]') as HTMLElement | null;
    if (el?.dataset.member) track('cal_booking_init', { member: el.dataset.member });
  </script>
)}
