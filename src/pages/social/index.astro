---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import SocialPostGenerator from "@/components/SocialPostGenerator";
import { teamMembers } from "@/lib/constants/team";
---

<BaseLayout title="Social Post Generator — Crafter Station" description="Generate LinkedIn posts for Crafter Station team members.">
  <Nav />
  <main class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
    <div class="mb-8">
      <h1 class="text-base font-bold text-foreground mb-2">Social Post Generator</h1>
      <p class="text-sm text-muted-foreground max-w-2xl">
        Generate LinkedIn-ready images for team members. Select a member, preview the card, and download as PNG.
      </p>
    </div>

    <SocialPostGenerator client:load members={teamMembers} />
  </main>
</BaseLayout>
