---
export const prerender = true;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/Nav.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import { getLangFromUrl } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);

const logoAssets = [
  { name: 'Logo (White)', description: 'Primary logo for dark backgrounds', file: '/brand/logo-white.svg', darkBg: true },
  { name: 'Logo (Black)', description: 'Logo for light backgrounds', file: '/brand/logo-black.svg', darkBg: false },
  { name: 'Wordmark (White)', description: 'Text-only wordmark', file: '/brand/wordmark-white.svg', darkBg: true },
  { name: 'Wordmark (Black)', description: 'Text-only wordmark for light', file: '/brand/wordmark-black.svg', darkBg: false },
  { name: 'Icon (White)', description: 'Icon mark for dark backgrounds', file: '/brand/icon-white.svg', darkBg: true },
  { name: 'Icon (Black)', description: 'Icon mark for light backgrounds', file: '/brand/icon-black.svg', darkBg: false },
];

const colorPalette = [
  { name: 'Void Black', hex: '#131010', usage: 'Page background, all surfaces' },
  { name: 'Off-White', hex: '#F2EDED', usage: 'Primary text, buttons, badges' },
  { name: 'Warm Gray', hex: '#B8B2B2', usage: 'Secondary text, nav links, labels' },
  { name: 'Muted Gray', hex: '#7F7A7A', usage: 'Tertiary text, metadata, counters' },
  { name: 'Dark Divider', hex: '#3D3838', usage: 'Section dividers, borders' },
  { name: 'Bullet', hex: '#716B6A', usage: '[*] markers, Fig labels, de-emphasized' },
];
---

<BaseLayout
  lang={lang}
  title="Brand — Crafter Station"
  description="Crafter Station brand assets, color palette, typography, and usage guidelines."
>
  <Nav />

  <main>
    <!-- Header -->
    <section class="border-b border-divider px-6 py-16 max-w-[1280px] mx-auto">
      <h1 class="text-base font-bold text-foreground mb-2">Brand</h1>
      <p class="text-sm text-muted-foreground max-w-2xl">
        Crafter Station brand assets, color palette, and typography guidelines.
        Use these assets when referencing Crafter Station in articles, presentations, or products.
      </p>
    </section>

    <!-- Logo assets -->
    <section class="border-b border-divider px-6 py-12 max-w-[1280px] mx-auto">
      <h2 class="text-xs font-bold text-bullet mb-6 uppercase tracking-widest">Logo assets</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-px border border-divider bg-divider">
        {logoAssets.map(asset => (
          <div class={`flex flex-col ${asset.darkBg ? 'bg-background' : 'bg-foreground'} p-8 gap-6`}>
            <div class="flex items-center justify-center h-16">
              <img src={asset.file} alt={asset.name} class="max-h-full max-w-full object-contain" />
            </div>
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class={`text-xs font-bold ${asset.darkBg ? 'text-foreground' : 'text-background'}`}>{asset.name}</p>
                <p class={`text-xs ${asset.darkBg ? 'text-muted-foreground' : 'text-background/70'} mt-0.5`}>{asset.description}</p>
              </div>
              <a
                href={asset.file}
                download
                class={`text-xs ${asset.darkBg ? 'text-muted-foreground hover:text-foreground' : 'text-background/70 hover:text-background'} transition-colors shrink-0`}
              >
                SVG ↓
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Color palette -->
    <section class="border-b border-divider px-6 py-12 max-w-[1280px] mx-auto">
      <h2 class="text-xs font-bold text-bullet mb-6 uppercase tracking-widest">Color palette</h2>
      <div class="flex flex-col gap-0 divide-y divide-divider border-t border-divider">
        {colorPalette.map((color, i) => (
          <div class="flex items-center gap-6 py-4">
            <span class="text-bullet text-xs select-none shrink-0 w-10">Fig {i + 1}.</span>
            <div
              class="w-10 h-10 border border-divider shrink-0"
              style={`background-color: ${color.hex}`}
            />
            <div class="flex-1 min-w-0">
              <p class="text-sm font-bold text-foreground">{color.name}</p>
              <p class="text-xs text-muted-foreground mt-0.5">{color.usage}</p>
            </div>
            <code class="text-xs text-bullet font-mono shrink-0">{color.hex}</code>
          </div>
        ))}
      </div>
    </section>

    <!-- Typography -->
    <section class="border-b border-divider px-6 py-12 max-w-[1280px] mx-auto">
      <h2 class="text-xs font-bold text-bullet mb-6 uppercase tracking-widest">Typography</h2>
      <div class="flex flex-col gap-8 max-w-2xl">
        <div class="flex items-start gap-4">
          <span class="text-bullet text-sm shrink-0 select-none">[*]</span>
          <div>
            <p class="text-sm font-bold text-foreground mb-1">IBM Plex Mono</p>
            <p class="text-xs text-muted-foreground mb-4">The only typeface. Used for everything — headlines, body, code, nav, labels.</p>
            <div class="flex flex-col gap-3">
              <p class="text-4xl font-bold text-foreground">Bold 700</p>
              <p class="text-2xl font-medium text-foreground">Medium 500</p>
              <p class="text-base text-foreground">Regular 400</p>
              <p class="text-sm text-muted-foreground">Secondary text — Regular 400</p>
              <p class="text-xs text-bullet">Tertiary / metadata — Regular 400</p>
            </div>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-bullet text-sm shrink-0 select-none">[*]</span>
          <div>
            <p class="text-sm font-bold text-foreground mb-1">Naming</p>
            <p class="text-xs text-muted-foreground">Always "Crafter Station" — two words, both capitalized. Never "CrafterStation", "crafter station", or abbreviated as "CS".</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Usage guidelines -->
    <section class="border-b border-divider px-6 py-12 max-w-[1280px] mx-auto">
      <h2 class="text-xs font-bold text-bullet mb-6 uppercase tracking-widest">Usage guidelines</h2>
      <div class="flex flex-col gap-4 max-w-2xl">
        {[
          'Use the white logo on dark backgrounds. Use the black logo on light backgrounds.',
          'Do not recolor the logo. Do not apply gradients, shadows, or effects.',
          'Maintain clear space around the logo equal to the height of the "C" in the wordmark.',
          'Do not stretch, rotate, or distort the logo in any direction.',
          'Contact hello@crafter.run for questions about brand usage.',
        ].map(guideline => (
          <div class="flex items-start gap-4">
            <span class="text-bullet text-sm shrink-0 mt-0.5 select-none">[*]</span>
            <p class="text-sm text-muted-foreground">{guideline}</p>
          </div>
        ))}
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
