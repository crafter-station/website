---
import BaseLayout from "@/layouts/BaseLayout.astro";
import MobileMenu from "@/components/MobileMenu.astro";
import { ThreeShader } from "@/components/ThreeShader";
import CrafterIcon from "@/icons/crafter.svg";
import GithubIcon from "@/icons/github.svg";
import LinkedinIcon from "@/icons/linkedin.svg";
import XIcon from "@/icons/x.svg";
import { teamMembers } from "@/lib/constants/team";
import { getCollection } from "astro:content";

// Custom styles for Backhouse-inspired animations

const projects = [
    {
        name: "tinte",
        description: "Theme generator for VSCode & shadcn/ui",
        href: "https://www.tinte.dev",
        tags: ["VSCode", "shadcn/ui"],
        stars: "500+",
    },
    {
        name: "lupa",
        description: "Knowledge Platform for AI Agents",
        href: "https://www.lupa.build",
        tags: ["AI", "RAG"],
        stars: "New",
    },
    {
        name: "elements",
        description: "Fullstack shadcn/ui components",
        href: "https://www.tryelements.dev/",
        tags: ["React", "Fullstack"],
        stars: "200+",
    },
    {
        name: "text0",
        description: "Absurdly smart autocomplete",
        href: "https://www.text0.dev",
        tags: ["AI", "Editor"],
        stars: "Winner",
    },
];

const posts = await getCollection("blog");
const publishedPosts = posts
    .filter((post) => import.meta.env.DEV || !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);
---

<BaseLayout
    title="Crafter Station"
    description="Open source community building developer tools in public. Based in Peru, building for the world."
>
    <div class="min-h-screen w-full flex bg-black">
        <!-- Left Sidebar - Minimal -->
        <aside
            class="hidden lg:flex flex-col justify-between w-44 px-6 py-8 shrink-0 fixed left-0 top-0 bottom-0 z-40 bg-black"
        >
            <a
                href="/"
                class="block w-fit"
            >
                <div class="p-2 border border-neutral-800 hover:border-primary/50 transition-colors">
                    <CrafterIcon class="size-5 text-primary" />
                </div>
            </a>

            <nav id="sidebar-nav" class="flex flex-col gap-0">
                <a
                    href="#hero"
                    data-section="hero"
                    class="nav-link font-mono text-[11px] text-neutral-600 hover:text-white transition-colors py-1.5 uppercase tracking-wider"
                    >[01] HOME</a
                >
                <a
                    href="#about"
                    data-section="about"
                    class="nav-link font-mono text-[11px] text-neutral-600 hover:text-white transition-colors py-1.5 uppercase tracking-wider"
                    >[02] ABOUT</a
                >
                <a
                    href="#projects"
                    data-section="projects"
                    class="nav-link font-mono text-[11px] text-neutral-600 hover:text-white transition-colors py-1.5 uppercase tracking-wider"
                    >[03] PROJECTS</a
                >
                <a
                    href="#team"
                    data-section="team"
                    class="nav-link font-mono text-[11px] text-neutral-600 hover:text-white transition-colors py-1.5 uppercase tracking-wider"
                    >[04] TEAM</a
                >
                <a
                    href="#community"
                    data-section="community"
                    class="nav-link font-mono text-[11px] text-neutral-600 hover:text-white transition-colors py-1.5 uppercase tracking-wider"
                    >[05] COMMUNITY</a
                >
                <a
                    href="#blog"
                    data-section="blog"
                    class="nav-link font-mono text-[11px] text-neutral-600 hover:text-white transition-colors py-1.5 uppercase tracking-wider"
                    >[06] BLOG</a
                >
                <div class="h-px bg-neutral-800 my-2"></div>
                <a
                    href="/brand"
                    class="font-mono text-[11px] text-neutral-600 hover:text-white transition-colors py-1.5 uppercase tracking-wider"
                    >BRAND</a
                >
            </nav>

            <div class="border-t border-neutral-800/50 pt-4">
                <p class="font-mono text-[10px] text-neutral-600 uppercase tracking-wider mb-2">RECENT WIN</p>
                <p class="text-xs text-neutral-500 mb-1.5">
                    text0 Hackathon
                </p>
                <a
                    href="https://text0.dev"
                    target="_blank"
                    class="font-mono text-[10px] text-primary hover:underline inline-block"
                    >VIEW →</a
                >
            </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 w-full">
            <!-- Section: Hero - Backhouse Style -->
            <section
                id="hero"
                class="relative min-h-screen flex flex-col"
            >
                <!-- Sticky Header - Enhanced -->
                <div class="sticky top-0 z-50 flex items-center justify-between font-mono text-[10px] px-6 md:px-12 lg:px-20 py-4 border-b border-neutral-800 backdrop-blur-xl bg-black/80 uppercase tracking-wider">
                    <div class="flex items-center gap-4">
                        <span class="size-1.5 bg-primary rounded-full animate-pulse"></span>
                        <span id="live-clock" class="text-primary font-semibold">[00:00:00 AM]</span>
                    </div>
                    <span class="hidden md:inline text-neutral-500">Lima, Peru</span>
                    <span class="text-neutral-600 hover:text-primary transition-colors cursor-default">[-12.0464°, -77.0428°]</span>
                </div>

                <!-- Hero Content - Centered -->
                <div class="relative flex-1 flex items-center justify-center px-6 md:px-12 lg:px-20 py-20">
                    <div class="max-w-2xl text-center z-10">
                        <!-- Badge -->
                        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-primary/10 border border-primary/20 mb-8">
                            <span class="size-1.5 bg-primary rounded-full animate-pulse"></span>
                            <span class="text-xs text-primary font-mono uppercase tracking-wider">300+ members</span>
                        </div>

                        <!-- Headline -->
                        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight tracking-tight mb-6">
                            Open source tools.<br />
                            Peru's tech community.
                        </h1>

                        <!-- Statement -->
                        <p class="text-base md:text-lg text-neutral-500 max-w-lg leading-relaxed mb-12 mx-auto">
                            Building in public since 2023.
                        </p>

                        <!-- CTAs -->
                        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                            <a
                                href="https://crafters.chat"
                                target="_blank"
                                class="inline-flex items-center gap-2 px-8 py-4 bg-white text-black font-semibold hover:bg-[#25D366] hover:text-white transition-colors w-full sm:w-auto justify-center"
                            >
                                Join 300+ crafters
                                <svg class="size-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
                                </svg>
                            </a>
                            <a
                                href="#projects"
                                class="inline-flex items-center gap-2 px-8 py-4 border border-neutral-700 text-white font-semibold hover:border-primary hover:text-primary transition-colors w-full sm:w-auto justify-center"
                            >
                                See what we build
                                <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                                </svg>
                            </a>
                        </div>
                    </div>

                    <!-- Three.js Shader Background -->
                    <div class="absolute inset-0 -z-10 overflow-hidden">
                        <ThreeShader variant="matrix" className="absolute inset-0 opacity-20" client:load />
                        <!-- Gradient overlay for depth -->
                        <div class="absolute left-0 right-0 top-20 h-[600px] opacity-40"
                             style="background: linear-gradient(90deg,
                                rgba(255, 80, 40, 0.3) 0%,
                                rgba(255, 160, 50, 0.4) 20%,
                                rgba(255, 200, 80, 0.5) 40%,
                                rgba(100, 200, 255, 0.4) 60%,
                                rgba(150, 120, 255, 0.3) 80%,
                                rgba(0, 255, 150, 0.25) 100%);
                                filter: blur(140px);">
                        </div>
                        <!-- Fade to black -->
                        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/60 to-black"></div>
                    </div>
                </div>
            </section>

            <!-- Section: About - Compact -->
            <section
                id="about"
                class="px-4 md:px-12 lg:pl-52 lg:pr-24 py-16 md:py-20 border-t border-neutral-900/50"
            >
                <div class="max-w-2xl mx-auto">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">
                        <!-- Left Column: Projects -->
                        <div>
                            <p class="font-mono text-[10px] text-neutral-600 uppercase tracking-wider mb-4">
                                (01) PROJECTS
                            </p>
                            <div class="space-y-1">
                                <a href="https://tinte.dev" target="_blank" class="block group">
                                    <p class="text-base text-neutral-400 group-hover:text-primary transition-colors">tinte</p>
                                </a>
                                <a href="https://tryelements.dev" target="_blank" class="block group">
                                    <p class="text-base text-neutral-400 group-hover:text-primary transition-colors">elements</p>
                                </a>
                                <a href="https://hack0.dev" target="_blank" class="block group">
                                    <p class="text-base text-neutral-400 group-hover:text-primary transition-colors">hack0</p>
                                </a>
                                <a href="https://text0.dev" target="_blank" class="block group">
                                    <p class="text-base text-neutral-400 group-hover:text-primary transition-colors">text0</p>
                                </a>
                                <a href="https://lupa.build" target="_blank" class="block group">
                                    <p class="text-base text-neutral-400 group-hover:text-primary transition-colors">lupa</p>
                                </a>
                            </div>
                        </div>

                        <!-- Right Column: Community -->
                        <div>
                            <p class="font-mono text-[10px] text-neutral-600 uppercase tracking-wider mb-4">
                                (02) COMMUNITY
                            </p>
                            <div class="space-y-1">
                                <p class="text-base text-neutral-400">180+ Members</p>
                                <p class="text-base text-neutral-400">5 Code Brews</p>
                                <p class="text-base text-neutral-400">Peru AI Hackathon</p>
                                <p class="text-base text-neutral-400">Next.js Winners</p>
                                <p class="text-base text-neutral-400">1K+ Stars</p>
                            </div>
                        </div>
                    </div>

                    <!-- Bottom: Stats -->
                    <div class="mt-12 pt-8 border-t border-neutral-900/30">
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                            <div>
                                <p class="font-mono text-[10px] text-neutral-600 uppercase tracking-wider mb-1">[FOUNDED]</p>
                                <p class="text-xl font-bold text-white">2023</p>
                            </div>
                            <div>
                                <p class="font-mono text-[10px] text-neutral-600 uppercase tracking-wider mb-1">[MEMBERS]</p>
                                <p class="text-xl font-bold text-white">180+</p>
                            </div>
                            <div>
                                <p class="font-mono text-[10px] text-neutral-600 uppercase tracking-wider mb-1">[STARS]</p>
                                <p class="text-xl font-bold text-white">1K+</p>
                            </div>
                            <div>
                                <p class="font-mono text-[10px] text-neutral-600 uppercase tracking-wider mb-1">[LOCATION]</p>
                                <p class="text-xl font-bold text-white">LIMA</p>
                            </div>
                        </div>

                        <div class="flex flex-col gap-2 text-xs text-neutral-600 mt-6">
                            <a href="https://org.crafter.run" target="_blank" class="hover:text-primary transition-colors font-mono">
                                → Meet the team at org.crafter.run
                            </a>
                            <a href="https://pulse.crafter.run" target="_blank" class="hover:text-primary transition-colors font-mono">
                                → Track our progress at pulse.crafter.run
                            </a>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Section: Projects - Improved Layout -->
            <section
                id="projects"
                class="px-4 md:px-12 lg:pl-52 lg:pr-24 py-12 md:py-16 bg-neutral-950/20"
            >
                <div class="max-w-4xl mx-auto">
                    <div class="mb-6">
                        <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">[03] Projects</h2>
                        <p class="text-sm text-neutral-500 font-mono">Building in public since 2023</p>
                    </div>

                    <!-- Projects Grid - 2 columns -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-1">
                        <!-- Column 1 -->
                        <div class="space-y-1">
                            <!-- text0 -->
                            <a href="https://text0.dev" target="_blank" class="group flex items-baseline gap-3 py-2 hover:text-primary transition-colors">
                                <span class="font-mono text-[10px] text-neutral-600 w-8 text-right">439</span>
                                <span class="text-base text-white group-hover:text-primary">text0</span>
                            </a>

                            <!-- elements -->
                            <a href="https://tryelements.dev" target="_blank" class="group flex items-baseline gap-3 py-2 hover:text-primary transition-colors">
                                <span class="font-mono text-[10px] text-neutral-600 w-8 text-right">373</span>
                                <span class="text-base text-white group-hover:text-primary">elements</span>
                            </a>

                            <!-- skills -->
                            <a href="https://github.com/crafter-station/skills" target="_blank" class="group flex items-baseline gap-3 py-2 hover:text-primary transition-colors">
                                <span class="font-mono text-[10px] text-neutral-600 w-8 text-right">32</span>
                                <span class="text-base text-white group-hover:text-primary">skills</span>
                            </a>

                            <!-- peru.ai-hackathon.co -->
                            <a href="https://peru.ai-hackathon.co" target="_blank" class="group flex items-baseline gap-3 py-2 hover:text-primary transition-colors">
                                <span class="font-mono text-[10px] text-neutral-600 w-8 text-right">29</span>
                                <span class="text-base text-white group-hover:text-primary">peru.ai-hackathon.co</span>
                            </a>

                            <!-- chess-battle -->
                            <a href="https://github.com/crafter-station/chess-battle" target="_blank" class="group flex items-baseline gap-3 py-2 hover:text-primary transition-colors">
                                <span class="font-mono text-[10px] text-neutral-600 w-8 text-right">28</span>
                                <span class="text-base text-white group-hover:text-primary">chess-battle</span>
                            </a>

                            <!-- hack0 -->
                            <a href="https://hack0.dev" target="_blank" class="group flex items-baseline gap-3 py-2 hover:text-primary transition-colors">
                                <span class="font-mono text-[10px] text-neutral-600 w-8 text-right">26</span>
                                <span class="text-base text-white group-hover:text-primary">hack0</span>
                            </a>
                        </div>

                        <!-- Column 2 -->
                        <div class="space-y-1">
                            <!-- pawboard - Featured -->
                            <a href="https://github.com/crafter-station/pawboard" target="_blank" class="group flex items-baseline gap-3 py-2 hover:text-primary transition-colors border-l-2 border-primary -ml-2 pl-2">
                                <span class="font-mono text-[10px] text-primary w-8 text-right">23</span>
                                <span class="text-base text-primary font-semibold">pawboard</span>
                            </a>

                            <!-- lupa -->
                            <a href="https://lupa.build" target="_blank" class="group flex items-baseline gap-3 py-2 hover:text-primary transition-colors">
                                <span class="font-mono text-[10px] text-neutral-600 w-8 text-right">22</span>
                                <span class="text-base text-white group-hover:text-primary">lupa</span>
                            </a>

                            <!-- i18n -->
                            <a href="https://github.com/crafter-station/i18n" target="_blank" class="group flex items-baseline gap-3 py-2 hover:text-primary transition-colors">
                                <span class="font-mono text-[10px] text-neutral-600 w-8 text-right">16</span>
                                <span class="text-base text-white group-hover:text-primary">i18n</span>
                            </a>

                            <!-- tinte -->
                            <a href="https://tinte.dev" target="_blank" class="group flex items-baseline gap-3 py-2 hover:text-primary transition-colors">
                                <span class="font-mono text-[10px] text-neutral-600 w-8 text-right">13</span>
                                <span class="text-base text-white group-hover:text-primary">tinte</span>
                            </a>

                            <!-- pintel -->
                            <a href="https://github.com/crafter-station/pintel" target="_blank" class="group flex items-baseline gap-3 py-2 hover:text-primary transition-colors">
                                <span class="font-mono text-[10px] text-neutral-600 w-8 text-right">9</span>
                                <span class="text-base text-white group-hover:text-primary">pintel</span>
                            </a>
                        </div>
                    </div>

                    <!-- View All Link -->
                    <div class="mt-10 flex justify-center">
                        <a
                            href="https://github.com/crafter-station"
                            target="_blank"
                            class="inline-flex items-center gap-3 px-6 py-3 font-mono text-sm text-neutral-400 hover:text-primary border border-neutral-800 hover:border-primary transition-all group"
                        >
                            <span>VIEW ALL ON GITHUB</span>
                            <svg
                                class="size-4 group-hover:translate-x-1 transition-transform"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"
                                />
                            </svg>
                        </a>
                    </div>
                </div>
            </section>

            <!-- Section: Team - Compact -->
            <section
                id="team"
                class="px-4 md:px-12 lg:pl-52 lg:pr-24 py-16 md:py-20 border-t border-neutral-900/50"
            >
                <div class="max-w-2xl mx-auto">
                    <div class="mb-6">
                        <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">[04] Team</h2>
                    </div>

                    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                        {
                            teamMembers.map((member, i) => (
                                <a
                                    href={`/team/${member.username}`}
                                    class="group block relative"
                                >
                                    <div class="mb-2">
                                        <p class="font-mono text-[10px] text-neutral-600 mb-1.5">
                                            [{String(i + 1).padStart(2, '0')}]
                                        </p>
                                        <div class="aspect-square overflow-hidden border border-neutral-900 group-hover:border-primary/30 transition-colors relative">
                                            <img
                                                src={member.photoUrl}
                                                alt={member.name}
                                                class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
                                            />
                                        </div>
                                    </div>
                                    <div>
                                        <p class="text-sm font-bold text-white group-hover:text-primary transition-colors mb-0.5">
                                            {member.name}
                                        </p>
                                        <p class="font-mono text-[10px] text-neutral-600 uppercase tracking-wider">
                                            {member.position}
                                        </p>
                                    </div>
                                    <div class="absolute bottom-0 left-0 w-0 h-px bg-primary group-hover:w-full transition-all duration-500 ease-out"></div>
                                </a>
                            ))
                        }
                    </div>
                </div>
            </section>

            <!-- Section: Community - Compact -->
            <section
                id="community"
                class="px-4 md:px-12 lg:pl-52 lg:pr-24 py-16 md:py-20 bg-neutral-950/20"
            >
                <div class="max-w-2xl mx-auto">
                    <div class="mb-6">
                        <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">[05] Community</h2>
                    </div>

                    <div class="space-y-4">
                        <!-- WhatsApp -->
                        <a
                            href="https://crafters.chat"
                            target="_blank"
                            class="group flex flex-col md:flex-row md:items-center md:justify-between py-4 border-b border-neutral-900/30 relative"
                        >
                            <div class="flex items-baseline gap-2 mb-1 md:mb-0">
                                <span class="font-mono text-[10px] text-neutral-600">[01]</span>
                                <h3 class="text-lg md:text-xl font-bold text-white group-hover:text-[#25D366] transition-colors leading-tight">
                                    WhatsApp
                                </h3>
                            </div>
                            <div class="ml-8 md:ml-0">
                                <span class="font-mono text-[10px] text-neutral-600">
                                    300+ members
                                </span>
                            </div>
                            <div class="absolute bottom-0 left-0 w-0 h-px bg-[#25D366] group-hover:w-full transition-all duration-500 ease-out"></div>
                        </a>

                        <!-- Discord -->
                        <a
                            href="https://discord.gg/QvsS4jNpKa"
                            target="_blank"
                            class="group flex flex-col md:flex-row md:items-center md:justify-between py-4 border-b border-neutral-900/30 relative"
                        >
                            <div class="flex items-baseline gap-2 mb-1 md:mb-0">
                                <span class="font-mono text-[10px] text-neutral-600">[02]</span>
                                <h3 class="text-lg md:text-xl font-bold text-white group-hover:text-[#5865F2] transition-colors leading-tight">
                                    Discord
                                </h3>
                            </div>
                            <div class="ml-8 md:ml-0">
                                <span class="font-mono text-[10px] text-neutral-600">
                                    chat
                                </span>
                            </div>
                            <div class="absolute bottom-0 left-0 w-0 h-px bg-[#5865F2] group-hover:w-full transition-all duration-500 ease-out"></div>
                        </a>

                        <!-- GitHub -->
                        <a
                            href="https://github.com/crafter-station"
                            target="_blank"
                            class="group flex flex-col md:flex-row md:items-center md:justify-between py-4 border-b border-neutral-900/30 relative"
                        >
                            <div class="flex items-baseline gap-2 mb-1 md:mb-0">
                                <span class="font-mono text-[10px] text-neutral-600">[03]</span>
                                <h3 class="text-lg md:text-xl font-bold text-white group-hover:text-primary transition-colors leading-tight">
                                    GitHub
                                </h3>
                            </div>
                            <div class="ml-8 md:ml-0">
                                <span class="font-mono text-[10px] text-neutral-600">
                                    open source
